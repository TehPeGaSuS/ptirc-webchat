{
    "windowTitle": "PTirc Webchat",
    "startupScreen": "welcome",
    "useMonospace": true,
    "hideAdvancedSettings": true,
    "warnOnExit": true,
    "quitMessage": "PTirc Web Chat - https://kiwi.ptirc.org/",
    "showEmojiPicker": true,
    "noticeActiveBuffer": true,
    "changeNickOnCollision": true,
    "showChanlistModes": true,
    "restricted": true,
    "language": "en-us",
    "showAwayStatusIndicators": false,
    "theme": "Dark",
    "themes": [
        { "name": "Default", "url": "static/themes/default" },
        { "name": "Dark", "url": "static/themes/dark" },
        { "name": "Coffee", "url": "static/themes/coffee" },
        { "name": "GrayFox", "url": "static/themes/grayfox" },
        { "name": "Nightswatch", "url": "static/themes/nightswatch" },
        { "name": "Osprey", "url": "static/themes/osprey" },
        { "name": "Radioactive", "url": "static/themes/radioactive" },
        { "name": "Sky", "url": "static/themes/sky" },
        { "name": "Elite", "url": "static/themes/elite" }
    ],
    "buffers" : {
        "messageLayout": "compact",
        "alert_on": "highlight",
        "timestamp_format": "%H:%M:%S",
        "show_timestamps": true,
        "scrollback_size": 250,
        "show_hostnames": true,
        "show_joinparts": true,
        "show_topics": true,
        "show_nick_changes": true,
        "show_mode_changes": true,
        "server_as_activity": true,
        "colour_nicknames_in_messages": true,
        "show_emoticons": false,
        "extra_formatting": true,
        "default_ban_mask": "*!*@%h",
        "default_kick_reason": "Your behaviour is not conducive to the desired environment.",
        "show_buffer_groups": false,
        "show_message_info": true,
        "who_loop": false,
        "share_typing": false,
        "flash_title": "highlight",
        "nicklist_avatars": false,
        "show_link_previews": false,
        "inline_link_auto_previews": false,
        "inline_link_auto_previews_query": false,
        "show_realnames": false,
        "remember_buffers": false,
        "state_key": false
    },
    "startupOptions" : {
        "server": "alpha.ptirc.org",
        "port": 7666,
        "tls": true,
        "direct": true,
        "channel": "#Portugal",
        "nick": "PTirc-??",
        "greetingText": "<img src='static/img/Big_Logo.png' width='64' height='64'><p>Welcome to PTirc</p>",
        "termsContent": "By connecting to the network, you declare that you are over 13 years of age and that you have read and accepted our <a href='https://ptirc.org/privacy-policy/'>Privacy Policy</a> and our <a href='https://ptirc.org/termos-de-servico-tos/'>Terms of Service</a>",
        "infoBackground": "https://picsum.photos/1900/1600",
        "buttonText": "Connect!",
        "gecos": "PTirc Webchat - https://chat.ptirc.org/"
    },
    "embedly": {
        "key": ""
    },
        "plugins": [
        { "name": "customise", "url": "static/plugins/customise.html" }
    ]
}
